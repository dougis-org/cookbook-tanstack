{
  "name": "cookbook-tanstack",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "migration:extract": "tsx scripts/migration/extract-laravel-sql.ts",
    "migration:import": "tsx scripts/migration/import-laravel-data.ts",
    "migration:transform": "tsx scripts/migration/transform-laravel-data.ts",
    "migration:verify-import": "tsx scripts/migration/verify-import.ts",
    "migration:validate-extraction": "tsx scripts/migration/validate-extraction.ts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "opsx:init-change": "sh scripts/init-change.sh",
    "lint:route-outlet": "node scripts/lint-route-outlet.cjs",
    "db:connect": "npx tsx -e \"import mongoose from 'mongoose'; import { config } from 'dotenv'; config({ path: '.env.local' }); config(); mongoose.connect(process.env.MONGODB_URI).then(() => { console.log('MongoDB connected successfully'); process.exit(0); }).catch(e => { console.error(e); process.exit(1); })\"",
    "db:seed": "npx tsx src/db/seeds/index.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-router-ssr-query": "^1.131.7",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "@trpc/client": "^11.10.0",
    "@trpc/server": "^11.10.0",
    "@trpc/tanstack-react-query": "^11.10.0",
    "better-auth": "^1.4.18",
    "chokidar": "^5.0.0",
    "dotenv": "^17.2.4",
    "lucide-react": "^0.561.0",
    "mongodb": "^6.17.0",
    "mongoose": "^8.15.0",
    "nitro": "latest",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.1",
    "readdirp": "^5.0.0",
    "superjson": "^2.2.6",
    "tailwindcss": "^4.0.6",
    "tsx": "^4.21.0",
    "vite-tsconfig-paths": "^6.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@bgotink/playwright-coverage": "^0.3.2",
    "@playwright/test": "^1.58.2",
    "@tanstack/devtools-vite": "^0.3.11",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^27.0.0",
    "mongodb-memory-server": "^10.1.4",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vitest": "^3.0.5",
    "web-vitals": "^5.1.0"
  }
}
