# MongoDB connection
# Default: local Docker MongoDB service (docker compose up -d)
MONGODB_URI=mongodb://localhost:27017/cookbook
# To use MongoDB Atlas instead (off-network / shared dev data), override with your SRV string:
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/cookbook?retryWrites=true&w=majority

# Better-Auth (generate secret with: openssl rand -base64 32)
BETTER_AUTH_SECRET=paste-output-of-openssl-rand-base64-32-here
BETTER_AUTH_URL=http://localhost:3000

# Domain redirect — requests arriving at any other host are 301-redirected here.
# Leave unset in local dev (disables redirect middleware).
# Production: APP_PRIMARY_URL=https://recipe.dougis.com
APP_PRIMARY_URL=

# Comma-separated list of origins Better Auth will trust beyond BETTER_AUTH_URL.
# Secure default is empty (only BETTER_AUTH_URL trusted). In production, list all
# active domains: https://recipe.dougis.com,https://cookbook-tanstack.fly.dev
BETTER_AUTH_TRUSTED_ORIGINS=

# Mailtrap SMTP Configuration
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=your-mailtrap-user
MAILTRAP_PASS=your-mailtrap-password
MAIL_FROM="Cookbook App <noreply@example.com>"

# ImageKit credential for server-side recipe image uploads/deletes
IMAGE_KIT_API_KEY=        # Preferred private/API key (server-side only)
# IMAGEKIT_PRIVATE_KEY=   # Alternative SDK-native private key name

# Google Analytics 4 measurement ID (optional; production only)
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
