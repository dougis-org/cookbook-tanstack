# Database connection
#
# Option 1 — Local network server (preferred when on-network):
#   DATABASE_URL=postgresql://<user>:<pass>@sponky.dougis.com:5432/cookbook
#
# Option 2 — Docker compose (fallback for remote/offline work):
#   Start with: docker compose up -d
#   DATABASE_URL=postgresql://cookbook_user:cookbook_pass@localhost:5432/cookbook_db
#
DATABASE_URL=postgresql://cookbook_user:cookbook_pass@localhost:5432/cookbook_db

# Better-Auth (generate secret with: openssl rand -base64 32)
BETTER_AUTH_SECRET=paste-output-of-openssl-rand-base64-32-here
BETTER_AUTH_URL=http://localhost:3000
