# MongoDB connection
# Default: local Docker MongoDB service (docker compose up -d)
MONGODB_URI=mongodb://localhost:27017/cookbook
# To use MongoDB Atlas instead (off-network / shared dev data), override with your SRV string:
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/cookbook?retryWrites=true&w=majority

# Better-Auth (generate secret with: openssl rand -base64 32)
BETTER_AUTH_SECRET=paste-output-of-openssl-rand-base64-32-here
BETTER_AUTH_URL=http://localhost:3000

# Domain redirect — requests arriving at any other host are 301-redirected here.
# Leave unset in local dev (disables redirect middleware).
# Production: APP_PRIMARY_URL=https://recipe.dougis.com
APP_PRIMARY_URL=

# Comma-separated list of origins Better Auth will trust beyond BETTER_AUTH_URL.
# Secure default is empty (only BETTER_AUTH_URL trusted). In production, list all
# active domains: https://recipe.dougis.com,https://cookbook-tanstack.fly.dev
BETTER_AUTH_TRUSTED_ORIGINS=

# Mailtrap — Email API token (Mailtrap dashboard → API Tokens)
MAILTRAP_API_TOKEN=
# Sender address shown in outgoing emails (must be an authenticated sending domain or Mailtrap demo domain)
MAIL_FROM="Cookbook App <noreply@yourdomain.com>"
# Optional: route mail to a Mailtrap sandbox inbox (local/dev only)
# MAILTRAP_INBOX_ID=your-sandbox-inbox-id
# MAILTRAP_USE_SANDBOX=true

# ImageKit credential for server-side recipe image uploads/deletes
IMAGE_KIT_API_KEY=        # Preferred private/API key (server-side only)
# IMAGEKIT_PRIVATE_KEY=   # Alternative SDK-native private key name

# Stripe billing
# Get keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=              # Server-side only — never expose to client
VITE_STRIPE_PUBLISHABLE_KEY=    # Safe for client (Stripe.js)
STRIPE_WEBHOOK_SECRET=          # Stripe CLI: stripe listen --print-secret

# Stripe price IDs (from Stripe dashboard → Products)
STRIPE_PRICE_PREP_COOK_MONTHLY=
STRIPE_PRICE_PREP_COOK_ANNUAL=
STRIPE_PRICE_SOUS_CHEF_MONTHLY=
STRIPE_PRICE_SOUS_CHEF_ANNUAL=
STRIPE_PRICE_EXEC_CHEF_MONTHLY=
STRIPE_PRICE_EXEC_CHEF_ANNUAL=

# Google Analytics 4 measurement ID (optional; production only)
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Google AdSense ad unit IDs (optional; production only)
# Create display units in AdSense, then paste the numeric slot IDs below.
# VITE_GOOGLE_ADSENSE_TOP_SLOT_ID=1234567890
# VITE_GOOGLE_ADSENSE_BOTTOM_SLOT_ID=2345678901
