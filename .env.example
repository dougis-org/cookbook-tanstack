# MongoDB connection
# Default: local Docker MongoDB service (docker compose up -d)
MONGODB_URI=mongodb://localhost:27017/cookbook
# To use MongoDB Atlas instead (off-network / shared dev data), override with your SRV string:
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/cookbook?retryWrites=true&w=majority

# Better-Auth (generate secret with: openssl rand -base64 32)
BETTER_AUTH_SECRET=paste-output-of-openssl-rand-base64-32-here
BETTER_AUTH_URL=http://localhost:3000
